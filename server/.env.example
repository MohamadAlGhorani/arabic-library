NODE_ENV=development
PORT=5001

# Development: use arabic-library-dev database
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/arabic-library-dev?retryWrites=true&w=majority

# Production: use arabic-library database (set NODE_ENV=production)
# MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/arabic-library?retryWrites=true&w=majority

JWT_SECRET=your_jwt_secret_here
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_app_password
